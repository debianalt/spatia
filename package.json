{
  "name": "neahub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "preview:cf": "npm run build && npx wrangler pages dev build/",
    "deploy": "npm run build && npx wrangler pages deploy build/ --project-name neahub",
    "push-deploy": "git push origin master:main && npm run deploy -- --branch main"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "svelte": "^5.20.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@duckdb/duckdb-wasm": "^1.29.0",
    "apache-arrow": "^18.1.0",
    "maplibre-gl": "^5.1.0",
    "pmtiles": "^4.4.0"
  }
}