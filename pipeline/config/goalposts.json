  "pca_variable_selection": {
    "flood_risk":              ["c_occurrence", "c_recurrence", "c_extent"],
    "environmental_risk":      ["c_fire", "c_deforest", "c_thermal_amp", "c_slope", "c_hand"],
    "climate_comfort":         ["c_heat_day", "c_precipitation", "c_frost", "c_water_stress"],
    "green_capital":           ["c_ndvi", "c_treecover", "c_npp", "c_lai"],
    "change_pressure":         ["c_viirs_trend", "c_ghsl_change", "c_hansen_loss", "c_ndvi_trend"],
    "location_value":          ["c_access_20k", "c_nightlights", "c_slope", "c_road_dist"],
    "agri_potential":          ["c_soc", "c_ph_optimal", "c_clay", "c_precipitation", "c_gdd"],
    "forest_health":           ["c_ndvi_trend", "c_loss_ratio", "c_gpp", "c_et"],
    "carbon_stock":            ["c_agb_cci", "c_total_carbon", "c_soc", "c_net_flux"],
    "productive_activity":     ["c_viirs", "c_npp", "c_ndvi", "c_forest_loss"],
    "deforestation_dynamics":  ["c_loss_rate", "c_cumulative"],
    "pm25_drivers":            ["c_pm25_mean", "c_fire", "c_climate"]
