    "c_built":         {"lo": 0,     "hi": 30,    "tier": 2, "unit": "%",          "invert": false},
    "c_forest_loss":   {"lo": 0,     "hi": 25,    "tier": 2, "unit": "%",          "invert": false},
    "c_lst":           {"lo": 15,    "hi": 42,    "tier": 2, "unit": "°C",         "invert": false},
    "c_viirs":         {"lo": 0,     "hi": 15,    "tier": 2, "unit": "nW/cm2/sr",  "invert": true}
